<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title or "Coherence" }}</title>
    <meta name="description" content="{{ description or "A bounded-claim machine for software engineering." }}">
    <link rel="stylesheet" href="/assets/style.css?v={{ cssHash }}">
    <script>
      (function() {
        var theme = localStorage.getItem("theme");
        if (!theme) {
          theme = matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        }
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        }
        var palette = localStorage.getItem("palette");
        if (palette) {
          document.documentElement.setAttribute("data-palette", palette);
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-row">
        <a class="brand" href="/">Coherence</a>
        <nav class="nav" aria-label="Main navigation">
          <a href="/docs/">Docs</a>
          <a href="/blog/">Blog</a>
          <a href="/cases/">Cases</a>
          <a href="/ideas/">Ideas</a>
          <a href="https://github.com/usecoherence/coherence">GitHub</a>
        </nav>
        <div class="header-tools">
          <button class="theme-toggle" aria-label="Toggle theme" onclick="toggleTheme()">&#127763;</button>
          <button class="palette-pick" aria-label="Pick a color palette" onclick="randomPalette()">&#127912;</button>
        </div>
      </div>
    </header>

    {% set section = "Page" %}
    {% if page.url == "/" %}
      {% set section = "Home" %}
    {% elif page.url.startsWith("/docs/") %}
      {% set section = "Docs" %}
    {% elif page.url.startsWith("/blog/") %}
      {% set section = "Blog" %}
    {% elif page.url.startsWith("/cases/") %}
      {% set section = "Case" %}
    {% elif page.url.startsWith("/ideas/") %}
      {% set section = "Idea" %}
    {% endif %}

    <div class="page-shell">
      <main class="content">
        {% if page.url != "/" %}
          <div class="article-kicker">
            <span>{{ section }}</span>
            {% if page.url.includes("draft") %}<span>Draft</span>{% else %}<span>Published</span>{% endif %}
          </div>
          <nav class="breadcrumbs" aria-label="Breadcrumb">
            <a href="/">Home</a>
            {%- set parts = page.url | split("/") -%}
            {%- set full = "" -%}
            {%- for part in parts -%}
              {%- if part -%}
                {%- set full = full + part + "/" -%}
                {%- if page.url == "/" + full -%}
                  <span aria-current="page">{{ title }}</span>
                {%- else -%}
                  <a href="/{{ full }}">{{ part | replace("-", " ") | capitalize }}</a>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </nav>
        {% endif %}
        {{ content | safe }}
      </main>

      <aside class="toc" aria-label="Table of contents" hidden>
        <div class="toc-title">On this page</div>
        <nav class="toc-nav"></nav>
      </aside>
    </div>

    <script>
      function toggleTheme() {
        var html = document.documentElement;
        var isDark = html.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      }

      var palettes = ["default", "slate", "forest", "rust", "lavender"];

      function randomPalette() {
        var html = document.documentElement;
        var current = html.getAttribute("data-palette") || "default";
        var next;
        do {
          next = palettes[Math.floor(Math.random() * palettes.length)];
        } while (next === current && palettes.length > 1);
        html.setAttribute("data-palette", next === "default" ? "" : next);
        localStorage.setItem("palette", next === "default" ? "" : next);
      }

      (function buildToc() {
        var toc = document.querySelector(".toc");
        var nav = document.querySelector(".toc-nav");
        if (!toc || !nav) return;

        var headings = Array.prototype.slice.call(document.querySelectorAll(".content h2, .content h3"));
        if (headings.length < 2) return;

        headings.forEach(function(heading) {
          if (!heading.id) {
            heading.id = heading.textContent
              .toLowerCase()
              .replace(/[^a-z0-9]+/g, "-")
              .replace(/^-|-$/g, "");
          }

          var link = document.createElement("a");
          link.href = "#" + heading.id;
          link.textContent = heading.textContent;
          link.className = "toc-link toc-link-" + heading.tagName.toLowerCase();
          nav.appendChild(link);
        });

        toc.hidden = false;
      })();
    </script>
  </body>
</html>
